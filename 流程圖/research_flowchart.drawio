                </mxCell>
                <mxCell id="enrollment_box" value="納入標準&#10;&#10;(1) 年滿20歲&#10;(2) 慢性心衰竭，病情穩定&#10;(3) NYHA II-III級&#10;(4) 可參與中等強度運動&#10;(5) 能操作智慧裝置&#10;(6) 簽署知情同意書" style="rounded=1;arcSize=8;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2.5;fontSize=11;align=left;verticalAlign=top;padding=8px;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
                    <mxGeometry x="70" y="140" width="400" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="exclusion_box" value="排除標準&#10;&#10;(1) 絕對禁忌症&#10;(2) NYHA I或IV級&#10;(3) 近3個月急性事件&#10;(4) 近3個月手術/裝置治療&#10;(5) 嚴重併發症&#10;(6) 認知/精神障礙&#10;(7) 懷孕或哺乳&#10;(8) 參與其他研究" style="rounded=1;arcSize=8;fillColor=#FCE4EC;strokeColor=#E91E63;strokeWidth=2.5;fontSize=11;align=left;verticalAlign=top;padding=8px;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
