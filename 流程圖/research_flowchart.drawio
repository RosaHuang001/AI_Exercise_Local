                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="arrow2b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;strokeWidth=2.5;endArrow=classic;" edge="1" parent="1" source="exclusion_box" target="baseline_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="baseline_box" value="第1階段：基線測量&#10;(MLHFQ、NYHA分級、人口學特徵、疾病史記錄)" style="rounded=1;arcSize=8;fillColor=#F0F4FF;strokeColor=#2196F3;strokeWidth=2.5;fontSize=12;align=center;verticalAlign=middle;padding=10px;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
