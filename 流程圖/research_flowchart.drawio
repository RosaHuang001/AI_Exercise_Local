        </mxCell>
        <mxCell id="enrollment_box" value="納入標準&#xa;&#xa;(1) 年滿20歲&#xa;(2) 慢性心衰竭，病情穩定&#xa;(3) NYHA II-III級&#xa;(4) 可參與中等強度運動&#xa;(5) 能操作智慧裝置&#xa;(6) 簽署知情同意書" style="rounded=1;arcSize=8;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2.5;fontSize=14;align=left;verticalAlign=top;padding=8px;fontFamily=Microsoft YaHei;" parent="1" vertex="1">
          <mxGeometry x="230" y="157" width="270" height="180" as="geometry" />
        </mxCell>
        <mxCell id="exclusion_box" value="排除標準&#xa;&#xa;(1) 絕對禁忌症&#xa;(2) NYHA I或IV級&#xa;(3) 近3個月急性事件&#xa;(4) 近3個月手術/裝置治療&#xa;(5) 嚴重併發症&#xa;(6) 認知/精神障礙&#xa;(7) 懷孕或哺乳&#xa;(8) 參與其他研究" style="rounded=1;arcSize=8;fillColor=#FCE4EC;strokeColor=#E91E63;strokeWidth=2.5;fontSize=14;align=left;verticalAlign=top;padding=8px;fontFamily=Microsoft YaHei;" parent="1" vertex="1">
          <mxGeometry x="580" y="157" width="260" height="180" as="geometry" />
        </mxCell>
        <mxCell id="baseline_box" value="第1階段：基線期（介入前）&#xa;(NYHA分級、人口學特徵、疾病史記錄、生理指標測量)" style="rounded=1;arcSize=8;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2.5;fontSize=14;align=center;verticalAlign=middle;padding=10px;fontFamily=Microsoft YaHei;" parent="1" vertex="1">
