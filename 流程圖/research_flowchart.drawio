        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;strokeWidth=2;endArrow=classic;fontSize=14;" parent="1" source="baseline_box" target="system_interaction_box" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="system_interaction_box" value="第2階段：平行介入期(共4週)&#xa;(受試者自主運動訓練 + 日記或系統記錄 + 避免其他運動介入)" style="rounded=1;arcSize=8;fillColor=#F9F5FF;strokeColor=#9C27B0;strokeWidth=2.5;fontSize=14;align=center;verticalAlign=middle;padding=10px;fontFamily=Microsoft YaHei;fontColor=default;" parent="1" vertex="1">
